# AI Teaching Assistant - Development Environment Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Application Settings
# =============================================================================
DEBUG=true
LOG_LEVEL=DEBUG

# =============================================================================
# Database Settings
# =============================================================================
# MySQL 9 for local development (default)
MYSQL_USER=ai_teaching
MYSQL_PASSWORD=ai_teaching_dev
MYSQL_DATABASE=ai_teaching_assistant
MYSQL_PORT=3306
DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_PASSWORD}@localhost:${MYSQL_PORT}/${MYSQL_DATABASE}
DATABASE_ECHO=true

# SQLite fallback (optional for quick local/unit tests)
# DATABASE_URL=sqlite:///./teaching_assistant.db

# =============================================================================
# Redis Settings (Optional)
# =============================================================================
# REDIS_URL=redis://localhost:6379/0
# REDIS_PORT=6379

# =============================================================================
# Security Settings
# =============================================================================
# WARNING: Change this in production!
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# AI/LLM Settings
# =============================================================================
# OpenAI API (leave empty to use local fallback)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# Local LLM (optional)
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL_PATH=

# DeepSeek API (set USE_DEEPSEEK=true to enable)
USE_DEEPSEEK=false
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_RETRY_DELAY=1.0

# =============================================================================
# Server Settings
# =============================================================================
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# =============================================================================
# CORS Settings
# =============================================================================
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# =============================================================================
# File Upload Settings
# =============================================================================
MAX_UPLOAD_SIZE=10485760
UPLOAD_STORAGE_BACKEND=local
ALLOWED_EXTENSIONS=[".py", ".js", ".ts", ".java", ".cpp", ".c", ".h", ".hpp", ".php", ".pdf", ".docx", ".txt"]

# Optional S3 / object storage settings
# UPLOAD_S3_BUCKET=ai-teaching-dev-uploads
# UPLOAD_S3_REGION=ap-southeast-1
# UPLOAD_S3_ENDPOINT_URL=
# UPLOAD_S3_KEY_PREFIX=uploads
# UPLOAD_S3_ACCESS_KEY_ID=
# UPLOAD_S3_SECRET_ACCESS_KEY=

# =============================================================================
# Plagiarism Detection Settings
# =============================================================================
PLAGIARISM_THRESHOLD=0.7
STORE_SUBMISSIONS=true

